{
  "type": "module",
  "version": "2.0.7",
  "scripts": {
    "build": "rolldown -c",
    "build:firefox": "rm -rf dist/firefox && pnpm build --environment BROWSER:firefox",
    "build:chrome": "rm -rf dist/chrome && pnpm build --environment BROWSER:chrome",
    "dev:firefox": "cd dist/firefox && web-ext run --config=../../web-ext-config.mjs --devtools",
    "dev:chrome": "cd dist/chrome && web-ext run --config=../../web-ext-config.mjs -t chromium --args='--auto-open-devtools-for-tabs'",
    "lint": "eslint .",
    "sign": "cd dist/firefox && web-ext sign --config=../../web-ext-config.mjs",
    "watch:firefox": "pnpm build:firefox -w",
    "watch:chrome": "pnpm build:chrome -w",
    "wlint": "cd dist/firefox && web-ext lint",
    "zip:firefox": "cd dist/firefox && web-ext build --config=../../web-ext-config.mjs",
    "zip:chrome": "tsx zip-chrome.ts",
    "upload:chrome": "tsx upload-chrome.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chrome-webstore-upload-cli": "^3.3.2",
    "dotenv": "^16.4.5",
    "es-toolkit": "^1.39.10",
    "glob": "^11.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.2.2",
    "@types/adm-zip": "^0.5.7",
    "@types/webextension-polyfill": "^0.12.3",
    "eslint": "^9.34.0",
    "eslint-plugin-format": "^1.0.1",
    "rolldown": "1.0.0-rc.17",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^3.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "web-ext": "^8.9.0",
    "webextension-polyfill": "^0.12.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9"
      }
    }
  }
}
